{
  "fieldlink": {
    "version": "1.1",
    "updated": "2026-03-22T00:00:00Z",
    "role": ["fractals", "core", "engine"],

    "exports": [
      { "path": "glyph_set.json", "description": "Canonical glyph definitions (22 symbols)" },
      { "path": "bloom_logic.json", "description": "Symbolic bloom relationships (glyph → related glyphs)" }
    ],

    "sources": [
      {
        "name": "atlas",
        "repo": "https://github.com/JinnZ2/Fractal-Compass-Atlas",
        "ref": "main",
        "paths": ["atlas/**/*.json", "atlas/**/*.md", "guides/**/*.md"],
        "mounts": [
          { "remote": "atlas/fractal_principles.md", "as": "atlas/remote/atlas/principles.md" }
        ],
        "consent": { "license": "MIT", "share_ok": true }
      }
    ],

    "local_manifests": [
      "*.py",
      "glyph_set.json",
      "bloom_logic.json"
    ],

    "merge": {
      "order": ["local", "atlas"],
      "strategy": "deep-merge"
    },

    "offline": false,
    "cache_dir": ".fieldcache",
    "integrity": { "enabled": true, "hash": "sha256", "allow_missing": true },
    "consent": { "license": "MIT", "share_ok": true, "redact_rules": ["**/private/**", "*.secrets.json"] }
  }
}
