{
  "fieldlink": {
    "version": "1.1",
    "updated": "2026-03-22T00:00:00Z",
    "role": ["fractals", "core", "engine"],

    "sources": [
      {
        "name": "atlas",
        "repo": "https://github.com/JinnZ2/Fractal-Compass-Atlas",
        "ref": "main",
        "paths": ["fractals/**/*.json", "atlas/**/*.json", "glyphs/**/*.json", "guides/**/*.md"],
        "mounts": [
          { "remote": "atlas/glyphs.json", "as": "atlas/remote/atlas/glyphs.json" },
          { "remote": "fractals/bloom.json", "as": "atlas/remote/atlas/bloom.json" }
        ],
        "consent": { "license": "MIT", "share_ok": true }
      }
    ],

    "local_manifests": [
      "*.py"
    ],

    "merge": {
      "order": ["local", "atlas"],
      "strategy": "deep-merge"
    },

    "offline": false,
    "cache_dir": ".fieldcache",
    "integrity": { "enabled": true, "hash": "sha256", "allow_missing": true },
    "consent": { "license": "MIT", "share_ok": true, "redact_rules": ["**/private/**", "*.secrets.json"] }
  }
}
